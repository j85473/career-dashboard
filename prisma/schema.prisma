generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pg_trgm]
}

model Job {
  id                    String                 @id @default(uuid())
  title                 String
  company               String
  description           String?
  location              String?
  url                   String?
  source                String?
  sourceId              String?
  canonicalUrl          String?
  fingerprint           String?                @unique
  postedAt              DateTime
  status                String                 @default("pending_af")
  scoringStatus         String                 @default("queued")
  scoreAttempts         Int                    @default(0)
  scoreError            String?
  fitScore              Int?
  fitCategory           String                 @default("unscored")
  fitRationale          String?
  tailoringAdvice       String?
  recommendedResume     String?
  tailoringStaged       Boolean                @default(false)
  passReason            String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  manualAts             String?
  batchJobId            String?
  experienceStatus      String                 @default("queued")
  reqFitRationale       String?
  reqFitScore           Int?
  afBatchId             String?
  contextBatched        Boolean                @default(false)
  jdBatchId             String?
  verificationStatus    String                 @default("pending")
  travelScore           Int?
  aimFitScore           Int?
  contextPacket         String?
  submittedResume       String?
  cooldownUntil         DateTime?
  luckyAimFitScore      Int?
  luckyFitCategory      String                 @default("unscored")
  luckyFitScore         Int?
  luckyPassReason       String?
  luckyScoreAttempts    Int                    @default(0)
  luckyScoreError       String?
  luckyStatus           String                 @default("none")
  luckyBatchId          String?
  compensation          String?
  deepseekScoreAttempts Int                    @default(0)
  deepseekScoreError    String?
  lastVerifiedAt        DateTime?
  observations          JobSourceObservation[]

  @@index([status])
  @@index([scoringStatus])
  @@index([luckyStatus])
  @@index([fingerprint])
  @@index([status, aimFitScore])
  @@index([status, createdAt])
  @@index([scoringStatus, status, aimFitScore])
  @@index([scoringStatus, deepseekScoreAttempts])
  @@index([luckyStatus, luckyAimFitScore])
  @@index([luckyBatchId])
  @@index([canonicalUrl])
  @@index([title(ops: raw("gin_trgm_ops"))], type: Gin)
  @@index([company(ops: raw("gin_trgm_ops"))], type: Gin)
  @@index([description(ops: raw("gin_trgm_ops"))], type: Gin)
}

model JobSourceObservation {
  id       String  @id @default(uuid())
  jobId    String
  source   String
  sourceId String
  url      String?
  job      Job     @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([source, sourceId])
}

model UserPreference {
  id        String   @id @default(uuid())
  text      String
  type      String
  createdAt DateTime @default(now())
}

model UsageTracking {
  id           String @id @default(uuid())
  date         String @unique
  tokens       Int    @default(0)
  inputTokens  Int    @default(0)
  outputTokens Int    @default(0)
  cost         Float  @default(0)
}

model UsedArticle {
  id        String   @id @default(uuid())
  url       String   @unique
  status    String
  createdAt DateTime @default(now())
}

model LinkedInDraft {
  id        String   @id @default(uuid())
  title     String
  postText  String
  url       String
  createdAt DateTime @default(now())
}

model AtsCompany {
  slug          String
  platform      String
  status        String    @default("active")
  failCount     Int       @default(0)
  nextCheckDate DateTime  @default(now())
  jobsFound     Int       @default(0)
  discoveredAt  DateTime  @default(now())
  lastCheckedAt DateTime?

  @@id([slug, platform])
  @@index([status, nextCheckDate])
}

model ContextProfile {
  id              String   @id @default("global")
  rulesText       String
  updatedAt       DateTime @updatedAt
  batchJobId      String?
  linkedinBatchId String?
}

model ContextRuleRevision {
  id                String   @id @default(uuid())
  contextProfileId  String
  previousRulesText String
  newRulesText      String
  sourceJobIds      String[]
  model             String
  promptVersion     String
  requestId         String?
  createdAt         DateTime @default(now())

  @@index([createdAt])
}

model AiUsageEvent {
  id               String   @id @default(uuid())
  provider         String
  purpose          String
  status           String
  model            String
  requestId        String?
  batchSize        Int      @default(0)
  latencyMs        Int
  attempt          Int      @default(1)
  finishReason     String?
  promptTokens     Int      @default(0)
  cacheHitTokens   Int      @default(0)
  cacheMissTokens  Int      @default(0)
  completionTokens Int      @default(0)
  reasoningTokens  Int      @default(0)
  totalTokens      Int      @default(0)
  estimatedCost    Float    @default(0)
  error            String?
  createdAt        DateTime @default(now())

  @@index([provider, createdAt])
  @@index([purpose, createdAt])
}

model JobScoreEvent {
  id                     String   @id @default(uuid())
  jobId                  String
  evaluationType         String
  model                  String
  promptVersion          String
  requestId              String?
  aimFitScore            Int?
  experienceFitScore     Int?
  travelScore            Int?
  domainMatch            Boolean?
  requiredDomain         String?
  candidateDomain        String?
  requiredYearsInDomain  Float?
  candidateYearsInDomain Float?
  passed                 Boolean
  aimReason              String?
  experienceReason       String?
  createdAt              DateTime @default(now())

  @@index([jobId, createdAt])
  @@index([model, promptVersion])
}

model IngestionSourceRun {
  id             String    @id @default(uuid())
  source         String
  status         String
  seenCount      Int       @default(0)
  insertedCount  Int       @default(0)
  duplicateCount Int       @default(0)
  filteredCount  Int       @default(0)
  errorCount     Int       @default(0)
  error          String?
  startedAt      DateTime  @default(now())
  finishedAt     DateTime?
  durationMs     Int?
  createdAt      DateTime  @default(now())

  @@index([source, createdAt])
  @@index([status, createdAt])
}

model WildcardProfile {
  id          String   @id @default("global")
  profileText String
  updatedAt   DateTime @updatedAt
}

model UsedWildcardQuery {
  id        String   @id @default(uuid())
  query     String   @unique
  createdAt DateTime @default(now())
}

model OutreachTarget {
  id               String   @id @default(uuid())
  publicIdentifier String?
  firstName        String
  lastName         String
  headline         String?
  company          String?
  linkedinUrl      String   @unique
  about            String?
  locationText     String?
  status           String   @default("inbox")
  generatedPitch   String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  email            String?
  generatedNote    String?
}
