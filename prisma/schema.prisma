generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Job {
  id                 String                 @id @default(uuid())
  title              String
  company            String
  description        String?
  location           String?
  url                String?
  source             String?
  sourceId           String?
  canonicalUrl       String?
  fingerprint        String?
  postedAt           DateTime
  status             String                 @default("pending_af")
  scoringStatus      String                 @default("queued")
  scoreAttempts      Int                    @default(0)
  scoreError         String?
  fitScore           Int?
  fitCategory        String                 @default("unscored")
  fitRationale       String?
  tailoringAdvice    String?
  recommendedResume  String?
  tailoringStaged    Boolean                @default(false)
  passReason         String?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  manualAts          String?
  batchJobId         String?
  experienceStatus   String                 @default("queued")
  reqFitRationale    String?
  reqFitScore        Int?
  afBatchId          String?
  contextBatched     Boolean                @default(false)
  jdBatchId          String?
  verificationStatus String                 @default("pending")
  travelScore        Int?
  aimFitScore        Int?
  contextPacket      String?
  submittedResume    String?
  cooldownUntil      DateTime?
  luckyAimFitScore   Int?
  luckyFitCategory   String                 @default("unscored")
  luckyFitScore      Int?
  luckyPassReason    String?
  luckyScoreAttempts Int                    @default(0)
  luckyScoreError    String?
  luckyStatus        String                 @default("none")
  observations       JobSourceObservation[]

  @@index([status])
  @@index([scoringStatus])
  @@index([luckyStatus])
  @@index([fingerprint])
}

model JobSourceObservation {
  id       String  @id @default(uuid())
  jobId    String
  source   String
  sourceId String
  url      String?
  job      Job     @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([source, sourceId])
}

model UserPreference {
  id        String   @id @default(uuid())
  text      String
  type      String
  createdAt DateTime @default(now())
}

model UsageTracking {
  id           String @id @default(uuid())
  date         String @unique
  tokens       Int    @default(0)
  inputTokens  Int    @default(0)
  outputTokens Int    @default(0)
  cost         Float  @default(0)
}

model UsedArticle {
  id        String   @id @default(uuid())
  url       String   @unique
  status    String
  createdAt DateTime @default(now())
}

model LinkedInDraft {
  id        String   @id @default(uuid())
  title     String
  postText  String
  url       String
  createdAt DateTime @default(now())
}

model AtsCompany {
  slug          String
  platform      String
  status        String    @default("active")
  failCount     Int       @default(0)
  nextCheckDate DateTime  @default(now())
  jobsFound     Int       @default(0)
  discoveredAt  DateTime  @default(now())
  lastCheckedAt DateTime?

  @@id([slug, platform])
}

model ContextProfile {
  id              String   @id @default("global")
  rulesText       String
  updatedAt       DateTime @updatedAt
  batchJobId      String?
  linkedinBatchId String?
}

model WildcardProfile {
  id          String   @id @default("global")
  profileText String
  updatedAt   DateTime @updatedAt
}

model UsedWildcardQuery {
  id        String   @id @default(uuid())
  query     String   @unique
  createdAt DateTime @default(now())
}

model OutreachTarget {
  id               String   @id @default(uuid())
  publicIdentifier String?
  firstName        String
  lastName         String
  headline         String?
  company          String?
  linkedinUrl      String   @unique
  about            String?
  locationText     String?
  status           String   @default("inbox")
  generatedPitch   String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  email            String?
  generatedNote    String?
}
