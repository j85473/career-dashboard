# Database Connection
DATABASE_URL="postgresql://user:password@localhost:5432/career_db"

# AI Model Keys
GEMINI_API_KEY="your_gemini_api_key_here"
DEEPSEEK_API_KEY="your_deepseek_api_key_here"

# DeepSeek scoring (accuracy-first defaults)
DEEPSEEK_SCORING_MODEL="deepseek-v4-pro"
DEEPSEEK_SCORING_MAX_TOKENS=8000
DEEPSEEK_WILDCARD_MAX_TOKENS=6000
DEEPSEEK_MAX_RETRIES=3
DEEPSEEK_TIMEOUT_MS=90000
DEEPSEEK_JOB_MAX_ATTEMPTS=6

# Scraping / Data Source APIs
SERPAPI_KEY="your_serpapi_key_here"
RAPIDAPI_KEY="your_rapidapi_key_here"
ADZUNA_APP_KEY="your_adzuna_app_key_here"
ADZUNA_APP_ID="your_adzuna_app_id_here"

CAREERONESTOP_USER_ID="your_careeronestop_user_id_here"
CAREERONESTOP_TOKEN="your_careeronestop_token_here"

# Fallback/Secondary API Keys (Optional)
SERPAPI_KEY_2="your_second_serpapi_key_here"
RAPIDAPI_KEY_2="your_second_rapidapi_key_here"

# Job source integrations (optional)
APIFY_API_TOKEN="your_apify_token_here"
JINA_API_KEY="your_jina_key_here"
USAJOBS_API_KEY="your_usajobs_api_key_here"
USAJOBS_USER_AGENT="your-email@example.com"

# Dashboard / automation authentication
# Browser: HTTP Basic auth with DASHBOARD_USERNAME + DASHBOARD_PASSWORD.
# If DASHBOARD_PASSWORD is omitted, browser login uses PIPELINE_SECRET.
# Cron: Authorization: Bearer PIPELINE_SECRET.
DASHBOARD_USERNAME="admin"
DASHBOARD_PASSWORD="replace_with_a_long_random_password"
PIPELINE_SECRET="replace_with_a_different_long_random_secret"
DASHBOARD_URL="http://localhost:3000"

# Local development only. Ignored when NODE_ENV=production.
DASHBOARD_AUTH_DISABLED="false"
